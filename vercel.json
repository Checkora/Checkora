{
  "version": 2,
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "bash build_files.sh",
  "outputDirectory": "public",
  "functions": {
    "api/wsgi.py": {
      "includeFiles": "game/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/wsgi" }
  ]
}
