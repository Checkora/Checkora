{
  "version": 2,
  "installCommand": "echo 'Python deps handled by runtime'",
  "buildCommand": "python3 build_vercel.py",
  "outputDirectory": "public",

  "functions": {
    "api/wsgi.py": {
      "includeFiles": "game/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/wsgi" }
  ]
}
